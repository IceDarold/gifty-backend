{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://giftyai.ru/contracts/analytics/event-envelope.v1.json",
  "title": "Analytics Event Envelope V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "version",
    "occurred_at",
    "source",
    "tenant_id",
    "dims",
    "metrics",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z0-9_.:-]+$"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["api", "worker", "scheduler", "internal"]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "session_id": {
      "type": ["string", "null"],
      "maxLength": 256
    },
    "user_id": {
      "type": ["string", "null"],
      "maxLength": 256
    },
    "dims": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "null"]
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer"]
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
